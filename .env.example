# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Project JWT secret (Dashboard → Settings → API → JWT Settings).
# Used to verify auth tokens locally, without a network call to Supabase.
SUPABASE_JWT_SECRET=

# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/auth/strava/callback

# AES-256 key for encrypting Strava tokens at rest.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# AI
OPENAI_API_KEY=

# App
PORT=3000
NODE_ENV=development
# Optional deep link to return to the app after a successful Strava connect.
APP_OAUTH_SUCCESS_REDIRECT=
