# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Project JWT secret (Dashboard → Settings → API → JWT Settings).
# Used to verify auth tokens locally, without a network call to Supabase.
SUPABASE_JWT_SECRET=

# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/auth/strava/callback
# Random secret used to validate Strava webhook subscription (any string).
STRAVA_WEBHOOK_VERIFY_TOKEN=your_random_secret_token
# Public HTTPS URL Strava will POST events to (e.g. https://api.yourdomain.com/webhooks/strava)
STRAVA_WEBHOOK_CALLBACK_URL=

# AES-256 key for encrypting Strava tokens at rest.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# AI
OPENAI_API_KEY=

# App
PORT=3000
NODE_ENV=development
# Mock all external APIs (Strava/Garmin/Whoop/OpenAI) in development. false in prod.
MOCK_EXTERNAL_APIS=false

# Shared secret for the daily recovery-score cron (Supabase Edge Function →
# POST /recovery/calculate-all). Must match the function's CRON_SECRET.
CRON_SECRET=

# Garmin Health API (OAuth 1.0a). Consumer key/secret from your Garmin developer
# program app; redirect URI must be whitelisted there. Host overrides optional.
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
GARMIN_REDIRECT_URI=
# GARMIN_REQUEST_TOKEN_URL=
# GARMIN_AUTHORIZE_URL=
# GARMIN_ACCESS_TOKEN_URL=
# GARMIN_API_BASE=

# Whoop Health API (OAuth 2.0). Client id/secret from your Whoop developer app;
# redirect URI must be whitelisted there. Host overrides optional.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=
# WHOOP_AUTH_URL=
# WHOOP_TOKEN_URL=
# WHOOP_API_BASE=
# Optional deep link to return to the app after a successful Strava connect.
APP_OAUTH_SUCCESS_REDIRECT=
