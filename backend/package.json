{
  "name": "cycling-ai-trainer-backend",
  "version": "0.1.0",
  "description": "API server for the AI Cycling Trainer app",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "jest",
    "seed": "node ../scripts/seedMockData.js",
    "seed:clear": "node ../scripts/clearMockData.js",
    "validate:mock": "node ../scripts/validateMockData.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.js"
    ],
    "testTimeout": 30000
  },
  "keywords": [
    "cycling",
    "ai",
    "strava",
    "training"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1"
  },
  "devDependencies": {
    "axios-mock-adapter": "^2.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
